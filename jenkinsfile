pipeline {

    agent any

    tools {
        nodejs 'NodeJS'
    }

    stages {

        stage('Verify Workspace') {
            steps {
                bat 'dir'
            }
        }

        stage('Verify Node') {
            steps {
                bat 'node -v'
                bat 'npm -v'
            }
        }

        stage('Install Dependencies') {
            steps {
                bat 'npm install'
            }
        }

        stage('Install Playwright Browsers') {
            steps {
                bat 'npx playwright install'
            }
        }

        stage('Run API Automation') {
            steps {
                bat 'npx playwright test'
            }
        }
    }
}