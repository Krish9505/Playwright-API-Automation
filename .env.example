# Environment Configuration
# Copy this file to .env and fill with your actual API keys
# NEVER commit .env file to git

# Select environment: dev, staging, or production
ENV=staging

# API Keys (Get these from your environment credentials)
DEV_API_KEY=your-dev-api-key-here
STAGING_API_KEY=your-staging-api-key-here
PROD_API_KEY=your-prod-api-key-here

# Optional: Custom timeouts (in milliseconds)
# REQUEST_TIMEOUT=30000
